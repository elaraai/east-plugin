{
  "name": "@elaraai/east-plugin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild hooks/prompt-submit.js hooks/session-start.js mcp/search-server.js --bundle --format=esm --platform=node --outdir=dist --preserve-symlinks",
    "generate-index": "npm run build && node dist/scripts/generate-index.js && npm run bundle"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "minisearch": "^7.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.18.1",
    "esbuild": "^0.27.3",
    "typescript": "~5.9.2"
  }
}
